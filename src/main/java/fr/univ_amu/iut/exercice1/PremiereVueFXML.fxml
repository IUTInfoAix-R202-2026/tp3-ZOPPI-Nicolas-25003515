<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.geometry.Insets?>                <!-- 2. imports : un par classe utilisée -->           <!--    (équivalent des import Java)    -->
<?import javafx.scene.layout.VBox?>

<!--
  TODO exercice 1 (étape 0) : écrire le contenu de cette vue FXML.

  La racine est déjà placée (un BorderPane) ainsi que les imports nécessaires.
  À vous d'ajouter l'intérieur :
    - <padding>     : 20 px de marge intérieure (utiliser <Insets .../>)
    - <top>         : un Label "Bienvenue dans le monde FXML !" stylé en gras 20px,
                      aligné au centre via BorderPane.alignment="CENTER".
    - <center>      : un Label explicatif (texte libre), wrapText="true", centré
                      dans la zone (BorderPane.alignment="CENTER") ET dont les
                      lignes sont centrées (textAlignment="CENTER", sinon le texte
                      qui passe à la ligne reste aligné à gauche).
    - <bottom>      : un Button "D'accord, c'est magique", aligné au centre.

  Aucun fx:controller n'est nécessaire (vue purement statique, pas de logique).

  Référez-vous à la section "Cheat-sheet FXML" du README pour la syntaxe XML
  générale, et à la Javadoc JavaFX 25 (https://openjfx.io/javadoc/25/) pour les
  attributs précis de chaque composant.
-->

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
  prefWidth="420.0" prefHeight="240.0">

  <padding>
    <Insets top="20" right="20" bottom="20" left="20" />
  </padding>
  <top>
    <Label text="Bienvenue dans le monde FXML !"
      BorderPane.alignment="CENTER"
      style="-fx-font-size: 20px;" />
  </top>
  <center>
    <Label text="caca pipi"
      wrapText="true"
      BorderPane.alignment="CENTER"
      textAlignment="CENTER" />
  </center>
  <bottom>
    <Button fx:id="button"
      text="D'accord,c'est magique."
      BorderPane.alignment="CENTER" />
  </bottom>
</BorderPane>